{
  "name": "mano",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "typecheck": "pnpm -r --parallel typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm --filter @mano/frontend test:e2e",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": "biome check --no-errors-on-unmatched --write"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "nano-staged": "^0.9.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
